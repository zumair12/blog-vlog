<% content_for :page_title, "Analytics" %>

<!-- Summary bar -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Total Views</p>
    <p class="text-3xl font-bold text-white"><%= number_with_delimiter(Post.sum(:views_count)) %></p>
    <p class="text-xs text-violet-400 mt-1">across all published posts</p>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Published Posts</p>
    <p class="text-3xl font-bold text-white"><%= Post.status_published.count %></p>
    <p class="text-xs text-emerald-400 mt-1"><%= Post.status_draft.count %> drafts</p>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Avg. Views / Post</p>
    <% avg = Post.status_published.count > 0 ? (Post.sum(:views_count).to_f / Post.status_published.count).round(1) : 0 %>
    <p class="text-3xl font-bold text-white"><%= number_with_delimiter(avg) %></p>
    <p class="text-xs text-indigo-400 mt-1">per published post</p>
  </div>
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-5">
    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Comments</p>
    <p class="text-3xl font-bold text-white"><%= number_with_delimiter(Comment.status_approved.count) %></p>
    <p class="text-xs text-amber-400 mt-1"><%= Comment.status_pending.count %> pending moderation</p>
  </div>
</div>

<!-- Two-column content -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

  <!-- Top Posts by Views -->
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-white mb-5">Top Posts by Views</h2>
    <% if @top_posts.any? %>
      <div class="space-y-3">
        <% @top_posts.each_with_index do |post, i| %>
          <% max_views = @top_posts.first.views_count.to_f.nonzero? || 1 %>
          <div class="space-y-1.5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 min-w-0">
                <span class="text-xs font-bold text-gray-600 w-5 text-right shrink-0">#<%= i + 1 %></span>
                <%= link_to post.title.truncate(45), post_path(post.slug), target: "_blank",
                    class: "text-sm text-gray-300 hover:text-violet-300 transition-colors truncate" %>
              </div>
              <span class="text-xs font-semibold text-gray-400 shrink-0 ml-2"><%= number_with_delimiter(post.views_count) %></span>
            </div>
            <!-- Progress bar -->
            <div class="h-1 bg-gray-800 rounded-full overflow-hidden ml-7">
              <div class="h-full bg-gradient-to-r from-violet-600 to-indigo-500 rounded-full transition-all duration-500"
                   style="width: <%= [(post.views_count.to_f / max_views * 100).round, 100].min %>%;"></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm text-center py-8">No view data yet.</p>
    <% end %>
  </div>

  <!-- Top Categories -->
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-white mb-5">Categories by Post Count</h2>
    <% if @top_categories.any? %>
      <div class="space-y-4">
        <% max_cat = @top_categories.map(&:posts_count).max.to_f.nonzero? || 1 %>
        <% @top_categories.each do |cat| %>
          <div class="space-y-1.5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="text-lg"><%= cat.icon %></span>
                <%= link_to cat.name, category_path(cat.slug), target: "_blank",
                    class: "text-sm text-gray-300 hover:text-white transition-colors" %>
              </div>
              <span class="text-xs font-semibold text-gray-400"><%= cat.posts_count %> posts</span>
            </div>
            <div class="h-1.5 bg-gray-800 rounded-full overflow-hidden">
              <div class="h-full rounded-full transition-all duration-500"
                   style="width: <%= [(cat.posts_count.to_f / max_cat * 100).round, 100].min %>%; background-color: <%= cat.color %>;"></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm text-center py-8">No categories yet.</p>
    <% end %>
  </div>

</div>

<!-- Popular Tags + Author Leaderboard -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  <!-- Top Tags -->
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-white mb-5">Popular Tags</h2>
    <% if @top_tags.any? %>
      <div class="flex flex-wrap gap-2">
        <% @top_tags.each do |tag| %>
          <%= link_to tag_path(tag.slug), target: "_blank",
              class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium hover:opacity-80 transition-opacity",
              style: "background-color: #{tag.color}20; color: #{tag.color}; border: 1px solid #{tag.color}30;" do %>
            #<%= tag.name %>
            <span class="text-xs opacity-60 font-normal"><%= tag.posts_count %></span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm text-center py-8">No tags yet.</p>
    <% end %>
  </div>

  <!-- Author Leaderboard -->
  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <h2 class="text-base font-semibold text-white mb-5">Top Authors</h2>
    <% authors = User.where(role: [:author, :admin])
                     .joins(:posts)
                     .where(posts: { status: :published })
                     .select("users.*, COUNT(posts.id) AS pub_count, SUM(posts.views_count) AS total_views")
                     .group("users.id")
                     .order("total_views DESC")
                     .limit(5) %>
    <% if authors.any? %>
      <div class="space-y-3">
        <% authors.each_with_index do |author, i| %>
          <div class="flex items-center gap-3">
            <span class="text-lg font-bold text-gray-700 w-5 text-center">#<%= i + 1 %></span>
            <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white font-bold text-sm shrink-0">
              <%= author.initials %>
            </div>
            <div class="flex-1 min-w-0">
              <%= link_to "@#{author.username}", user_path(author.username), target: "_blank",
                  class: "text-sm font-medium text-gray-300 hover:text-white transition-colors block truncate" %>
              <p class="text-xs text-gray-500"><%= author.pub_count %> posts · <%= number_with_delimiter(author.total_views.to_i) %> views</p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm text-center py-8">No author data yet.</p>
    <% end %>
  </div>

</div>
