<header class="bg-gray-900/50 backdrop-blur-xl border-b border-gray-800 px-6 py-3 flex items-center justify-between sticky top-0 z-30">
  <div class="flex items-center gap-3">
    <h1 class="text-lg font-semibold text-white"><%= content_for?(:page_title) ? yield(:page_title) : "Admin" %></h1>
    <% if content_for?(:page_subtitle) %>
      <span class="text-gray-500">·</span>
      <span class="text-sm text-gray-400"><%= yield(:page_subtitle) %></span>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <!-- View site button -->
    <%= link_to root_path, target: "_blank", class: "flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
      View Blog
    <% end %>

    <!-- Quick actions -->
    <% if current_user.role_admin? || current_user.role_author? %>
      <%= link_to new_admin_post_path, class: "flex items-center gap-1.5 px-3 py-1.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium rounded-lg transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        New Post
      <% end %>
    <% end %>

    <!-- Sign out -->
    <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center gap-1.5 px-3 py-1.5 text-sm text-gray-400 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      Sign Out
    <% end %>
  </div>
</header>
