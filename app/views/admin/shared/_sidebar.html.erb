<aside class="w-64 bg-gray-900 border-r border-gray-800 flex flex-col min-h-screen shrink-0" data-controller="admin-sidebar">

  <!-- Logo -->
  <div class="flex items-center gap-2 px-6 py-5 border-b border-gray-800">
    <div class="w-8 h-8 bg-gradient-to-br from-violet-500 to-indigo-600 rounded-lg flex items-center justify-center shadow-lg shadow-violet-500/25">
      <span class="text-white font-bold text-sm">BV</span>
    </div>
    <div>
      <div class="font-bold text-white text-base">BlogVlog</div>
      <div class="text-xs text-gray-500">Admin Panel</div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">

    <!-- Dashboard -->
    <div class="mb-2">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-3 mb-1">Overview</p>
      <%= link_to admin_root_path, class: sidebar_link_class("admin_dashboard") do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
        Dashboard
      <% end %>
      <%= link_to admin_analytics_path, class: sidebar_link_class("admin_analytics") do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Analytics
      <% end %>
    </div>

    <!-- Content -->
    <div class="mb-2">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-3 mb-1">Content</p>
      <%= link_to admin_posts_path, class: sidebar_link_class("admin_posts") do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Posts
        <%# Draft count badge %>
        <% draft_count = Post.status_draft.count %>
        <% if draft_count > 0 %>
          <span class="ml-auto bg-amber-500/20 text-amber-300 text-xs px-2 py-0.5 rounded-full"><%= draft_count %></span>
        <% end %>
      <% end %>
    </div>

    <!-- Moderation -->
    <div class="mb-2">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-3 mb-1">Moderation</p>
      <%= link_to admin_comments_path, class: sidebar_link_class("admin_comments") do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        Comments
        <% pending_count = Comment.status_pending.count %>
        <% if pending_count > 0 %>
          <span class="ml-auto bg-red-500/20 text-red-300 text-xs px-2 py-0.5 rounded-full"><%= pending_count %></span>
        <% end %>
      <% end %>
    </div>

    <!-- Taxonomy (admin only) -->
    <% if current_user.role_admin? %>
      <div class="mb-2">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-3 mb-1">Taxonomy</p>
        <%= link_to admin_categories_path, class: sidebar_link_class("admin_categories") do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
          Categories
        <% end %>
        <%= link_to admin_tags_path, class: sidebar_link_class("admin_tags") do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>
          Tags
        <% end %>
      </div>

      <div class="mb-2">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-3 mb-1">People</p>
        <%= link_to admin_users_path, class: sidebar_link_class("admin_users") do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          Users
        <% end %>
      </div>
    <% end %>

  </nav>

  <!-- User info at bottom -->
  <div class="border-t border-gray-800 p-4">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white font-semibold text-sm shrink-0">
        <%= current_user.initials %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-white truncate">@<%= current_user.username %></p>
        <p class="text-xs text-gray-500 capitalize"><%= current_user.role %></p>
      </div>
      <%= link_to root_path, class: "text-gray-500 hover:text-gray-300 transition-colors", title: "View site" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      <% end %>
    </div>
  </div>

</aside>
