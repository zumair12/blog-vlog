<% content_for :page_title, "Users" %>

<!-- Role filter -->
<div class="flex items-center gap-2 mb-6">
  <% [["All", ""], ["Admins", "admin"], ["Authors", "author"], ["Readers", "reader"]].each do |label, val| %>
    <%= link_to label, admin_users_path(role: val.presence),
        class: "px-3 py-1.5 rounded-lg text-sm transition-colors
          #{params[:role].to_s == val ? 'bg-violet-600 text-white font-medium' : 'bg-gray-900 border border-gray-700 text-gray-400 hover:text-white hover:border-gray-600'}" %>
  <% end %>
</div>

<div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-800 text-left">
        <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">User</th>
        <th class="hidden md:table-cell px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
        <th class="hidden lg:table-cell px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Posts</th>
        <th class="hidden lg:table-cell px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Joined</th>
        <th class="px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-800">
      <% @users.each do |user| %>
        <tr class="hover:bg-gray-800/30 transition-colors group">
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white font-semibold text-sm shrink-0">
                <%= user.initials %>
              </div>
              <div>
                <p class="text-sm font-medium text-white">@<%= user.username %></p>
                <p class="text-xs text-gray-500"><%= user.email %></p>
              </div>
            </div>
          </td>
          <td class="hidden md:table-cell px-4 py-3">
            <span class="text-xs px-2.5 py-1 rounded-full font-medium
              <%= user.role_admin? ? 'bg-violet-500/20 text-violet-300' :
                  user.role_author? ? 'bg-indigo-500/20 text-indigo-300' :
                  'bg-gray-500/20 text-gray-400' %>">
              <%= user.role.capitalize %>
            </span>
          </td>
          <td class="hidden lg:table-cell px-4 py-3 text-sm text-gray-400">
            <%= user.posts_count %>
          </td>
          <td class="hidden lg:table-cell px-4 py-3 text-sm text-gray-500">
            <%= user.created_at.strftime("%b %Y") %>
          </td>
          <td class="px-4 py-3 text-right">
            <div class="flex items-center justify-end gap-2 opacity-60 group-hover:opacity-100 transition-opacity">
              <!-- Change role dropdown -->
              <% unless user == current_user %>
                <% next_roles = User.roles.keys - [user.role] %>
                <% next_roles.each do |role| %>
                  <%= button_to change_role_admin_user_path(user), method: :patch,
                      params: { role: role },
                      class: "text-xs px-2.5 py-1 bg-gray-700 hover:bg-gray-600 text-gray-300 rounded-lg transition-colors",
                      title: "Set as #{role}" do %>
                    → <%= role.capitalize %>
                  <% end %>
                <% end %>
              <% end %>
              <%= link_to user_path(user.username), target: "_blank",
                  class: "p-1.5 text-gray-500 hover:text-gray-300 hover:bg-gray-700 rounded-lg transition-colors",
                  title: "View profile" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-6">
  <%= render "shared/pagination", collection: @users %>
</div>
