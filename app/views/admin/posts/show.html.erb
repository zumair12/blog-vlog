<% content_for :page_title, "View Post" %>
<% content_for :page_subtitle, @post.slug %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <!-- Post preview / info -->
  <div class="lg:col-span-2 bg-gray-900 border border-gray-800 rounded-2xl p-6">
    <div class="flex items-start justify-between mb-4">
      <div>
        <h1 class="text-2xl font-bold text-white mb-2" style="font-family: 'Playfair Display', serif;">
          <%= @post.title %>
        </h1>
        <div class="flex flex-wrap items-center gap-2 text-sm text-gray-400">
          <span>by @<%= @post.user.username %></span>
          <span>·</span>
          <span><%= @post.created_at.strftime("%b %d, %Y") %></span>
          <span>·</span>
          <span><%= @post.reading_time_text %></span>
          <span>·</span>
          <span><%= number_with_delimiter(@post.views_count) %> views</span>
        </div>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <span class="text-xs px-2.5 py-1 rounded-full font-medium
          <%= @post.status_published? ? 'bg-emerald-500/20 text-emerald-300' :
              @post.status_draft? ? 'bg-amber-500/20 text-amber-300' :
              'bg-gray-500/20 text-gray-400' %>">
          <%= @post.status.capitalize %>
        </span>
        <% if @post.featured? %>
          <span class="text-xs px-2 py-1 bg-amber-500/20 text-amber-300 rounded-full">★ Featured</span>
        <% end %>
      </div>
    </div>

    <% if @post.excerpt.present? %>
      <p class="text-gray-400 text-sm mb-6 italic border-l-2 border-violet-500 pl-3"><%= @post.excerpt %></p>
    <% end %>

    <!-- Content preview -->
    <div class="prose prose-sm prose-invert prose-violet max-w-none border border-gray-800 rounded-xl p-4 bg-gray-950 max-h-80 overflow-y-auto">
      <%= @post.content %>
    </div>
  </div>

  <!-- Actions sidebar -->
  <div class="space-y-4">

    <!-- Actions -->
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-4">
      <h3 class="text-sm font-semibold text-gray-300 mb-3">Actions</h3>
      <div class="space-y-2">
        <%= link_to edit_admin_post_path(@post), class: "flex items-center gap-2 w-full px-3 py-2.5 bg-violet-600/10 border border-violet-500/20 text-violet-300 hover:bg-violet-600/20 rounded-xl text-sm font-medium transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit Post
        <% end %>

        <% unless @post.status_published? %>
          <%= button_to publish_admin_post_path(@post), method: :patch, class: "flex items-center gap-2 w-full px-3 py-2.5 bg-emerald-600/10 border border-emerald-500/20 text-emerald-300 hover:bg-emerald-600/20 rounded-xl text-sm font-medium transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            Publish
          <% end %>
        <% end %>

        <% if @post.status_published? %>
          <%= button_to archive_admin_post_path(@post), method: :patch, class: "flex items-center gap-2 w-full px-3 py-2.5 bg-gray-700/30 border border-gray-700 text-gray-400 hover:text-gray-200 hover:bg-gray-700/50 rounded-xl text-sm font-medium transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
            Archive
          <% end %>
        <% end %>

        <% if @post.featured? %>
          <%= button_to unfeature_admin_post_path(@post), method: :patch, class: "flex items-center gap-2 w-full px-3 py-2.5 bg-amber-500/10 border border-amber-500/20 text-amber-300 hover:bg-amber-500/20 rounded-xl text-sm font-medium transition-colors" do %>
            ☆ Unfeature
          <% end %>
        <% else %>
          <%= button_to feature_admin_post_path(@post), method: :patch, class: "flex items-center gap-2 w-full px-3 py-2.5 bg-amber-500/10 border border-amber-500/20 text-amber-300 hover:bg-amber-500/20 rounded-xl text-sm font-medium transition-colors" do %>
            ★ Feature
          <% end %>
        <% end %>

        <% if @post.status_published? %>
          <%= link_to post_path(@post.slug), target: "_blank", class: "flex items-center gap-2 w-full px-3 py-2.5 bg-gray-700/30 border border-gray-700 text-gray-400 hover:text-gray-200 rounded-xl text-sm transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            View Live
          <% end %>
        <% end %>

        <%= button_to admin_post_path(@post), method: :delete,
            class: "flex items-center gap-2 w-full px-3 py-2.5 bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 rounded-xl text-sm font-medium transition-colors",
            data: { turbo_confirm: "Permanently delete '#{@post.title}'?" } do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Delete Post
        <% end %>
      </div>
    </div>

    <!-- Meta -->
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-4 text-sm space-y-3">
      <h3 class="font-semibold text-gray-300 mb-3">Details</h3>
      <div class="flex justify-between"><span class="text-gray-500">Category</span><span class="text-gray-300"><%= @post.category&.name || "—" %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Comments</span><span class="text-gray-300"><%= @post.comments_count %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Tags</span><span class="text-gray-300 text-right max-w-[60%] truncate"><%= @post.tags.pluck(:name).join(", ").presence || "—" %></span></div>
      <div class="flex justify-between"><span class="text-gray-500">Published</span><span class="text-gray-300"><%= @post.published_at&.strftime("%b %d, %Y") || "—" %></span></div>
    </div>

    <%= link_to "← Back to Posts", admin_posts_path, class: "block text-center text-sm text-gray-500 hover:text-gray-300 transition-colors" %>
  </div>
</div>
