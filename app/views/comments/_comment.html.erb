<div id="comment-<%= comment.id %>" class="flex gap-3">
  <!-- Avatar -->
  <div class="shrink-0">
    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white font-semibold text-sm">
      <%= comment.user.initials %>
    </div>
  </div>

  <!-- Body -->
  <div class="flex-1 min-w-0">
    <div class="bg-gray-800/50 rounded-xl px-4 py-3 border border-gray-700/50">
      <div class="flex items-center justify-between mb-2">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-white">@<%= comment.user.username %></span>
          <span class="text-xs text-gray-500"><%= time_ago_in_words(comment.created_at) %> ago</span>
          <% if comment.status_pending? %>
            <span class="text-xs bg-amber-500/20 text-amber-300 px-2 py-0.5 rounded-full">Pending</span>
          <% end %>
        </div>
        <% if user_signed_in? && (current_user == comment.user || current_user.role_admin?) %>
          <%= button_to post_comment_path(comment.post.slug, comment), method: :delete,
              class: "text-xs text-gray-500 hover:text-red-400 transition-colors",
              data: { turbo_confirm: "Delete this comment?" } do %>
            Delete
          <% end %>
        <% end %>
      </div>
      <p class="text-sm text-gray-300 leading-relaxed"><%= comment.body %></p>
    </div>

    <!-- Reply form trigger -->
    <% if user_signed_in? && comment.top_level? %>
      <div class="mt-2">
        <button class="text-xs text-gray-500 hover:text-violet-400 transition-colors"
                data-controller="reply-toggle"
                data-action="click->reply-toggle#toggle">
          Reply
        </button>
        <div data-reply-toggle-target="form" class="hidden mt-3">
          <%= form_with model: [comment.post, Comment.new], class: "flex gap-2" do |f| %>
            <%= f.hidden_field :parent_id, value: comment.id %>
            <%= f.text_field :body, placeholder: "Reply to @#{comment.user.username}...",
                class: "flex-1 bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-500 transition-colors" %>
            <%= f.submit "Reply", class: "px-3 py-2 bg-violet-600 hover:bg-violet-500 text-white text-xs font-medium rounded-lg transition-colors cursor-pointer" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Replies -->
    <% if comment.replies.any? %>
      <div class="mt-4 space-y-3 pl-4 border-l-2 border-gray-700/50">
        <% comment.replies.each do |reply| %>
          <%= render "comments/comment", comment: reply %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
