<% content_for :title, "Categories" %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-10 text-center">
    <h1 class="text-3xl font-bold text-white mb-2" style="font-family: 'Playfair Display', serif;">Browse by Category</h1>
    <p class="text-gray-400">Explore posts organized by topic</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @categories.each do |cat| %>
      <%= link_to category_path(cat.slug), class: "group bg-gray-900 border border-gray-800 rounded-2xl p-6 hover:border-gray-700 hover:shadow-xl hover:shadow-black/20 transition-all duration-300" do %>
        <div class="flex items-start justify-between mb-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl" style="background-color: <%= cat.color %>20;">
            <%= cat.icon %>
          </div>
          <span class="text-sm font-semibold px-2.5 py-1 rounded-full text-white" style="background-color: <%= cat.color %>CC;">
            <%= cat.posts_count %>
          </span>
        </div>
        <h2 class="text-base font-bold text-white group-hover:text-violet-300 transition-colors mb-1"><%= cat.name %></h2>
        <% if cat.description.present? %>
          <p class="text-sm text-gray-400 line-clamp-2"><%= cat.description %></p>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
