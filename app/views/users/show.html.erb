<% content_for :title, "@#{@user.username}" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <!-- Profile header -->
  <div class="bg-gradient-to-br from-violet-900/20 to-indigo-900/20 border border-gray-800 rounded-2xl p-8 mb-10 flex flex-col sm:flex-row items-center sm:items-start gap-6">
    <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white font-bold text-2xl shrink-0">
      <% if @user.avatar.attached? %>
        <%= image_tag @user.avatar, class: "w-full h-full rounded-2xl object-cover" %>
      <% else %>
        <%= @user.initials %>
      <% end %>
    </div>
    <div class="flex-1 text-center sm:text-left">
      <h1 class="text-2xl font-bold text-white mb-0.5">@<%= @user.username %></h1>
      <p class="text-sm text-violet-400 font-medium mb-2 capitalize"><%= @user.role %></p>
      <% if @user.bio.present? %>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xl mb-3"><%= @user.bio %></p>
      <% end %>
      <div class="flex flex-wrap items-center justify-center sm:justify-start gap-4 text-sm text-gray-500">
        <span><%= @user.published_posts_count %> posts</span>
        <% if @user.website.present? %>
          <a href="<%= @user.website %>" target="_blank" rel="noopener noreferrer" class="text-violet-400 hover:text-violet-300 transition-colors">🌐 Website</a>
        <% end %>
        <% if @user.twitter_handle.present? %>
          <a href="https://twitter.com/<%= @user.twitter_handle %>" target="_blank" rel="noopener noreferrer" class="text-violet-400 hover:text-violet-300 transition-colors">𝕏 @<%= @user.twitter_handle %></a>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Posts grid -->
  <% if @posts.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      <% @posts.each do |post| %>
        <%= render "posts/card", post: post %>
      <% end %>
    </div>
    <%= render "shared/pagination", collection: @posts %>
  <% else %>
    <div class="text-center py-20 text-gray-500">
      <p class="text-4xl mb-3">✍️</p>
      <p>No published posts yet.</p>
    </div>
  <% end %>
</div>
