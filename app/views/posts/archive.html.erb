<% content_for :title, "Archive" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-10">
    <h1 class="text-3xl font-bold text-white" style="font-family: 'Playfair Display', serif;">Archive</h1>
    <p class="text-gray-400 mt-1">All posts, organized by year</p>
  </div>

  <% @posts_by_year.each do |year, posts| %>
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-white mb-4 border-b border-gray-800 pb-3 flex items-center gap-3">
        <span><%= year %></span>
        <span class="text-sm font-normal text-gray-500 bg-gray-800 px-2.5 py-1 rounded-full"><%= posts.count %> posts</span>
      </h2>
      <div class="space-y-3">
        <% posts.each do |post| %>
          <div class="flex items-baseline gap-4 group">
            <span class="text-gray-600 text-sm font-mono shrink-0 w-16"><%= post.published_at.strftime("%b %d") %></span>
            <div class="flex-1 flex items-baseline gap-3">
              <%= link_to post.title, post_path(post.slug), class: "text-gray-300 hover:text-white group-hover:text-violet-300 transition-colors font-medium" %>
              <% if post.category %>
                <span class="hidden sm:inline text-xs px-2 py-0.5 rounded text-white shrink-0" style="background-color: <%= post.category.color %>CC;"><%= post.category.name %></span>
              <% end %>
            </div>
            <span class="text-xs text-gray-600 shrink-0"><%= post.reading_time_text %></span>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @posts_by_year.empty? %>
    <div class="text-center py-20 text-gray-500">
      <p class="text-4xl mb-3">📚</p>
      <p>No posts yet.</p>
    </div>
  <% end %>
</div>
