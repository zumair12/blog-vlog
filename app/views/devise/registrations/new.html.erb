<div class="min-h-screen flex items-center justify-center px-4 py-16">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(120,119,198,0.12),rgba(255,255,255,0))] pointer-events-none"></div>

  <div class="relative w-full max-w-md">
    <!-- Logo -->
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-flex items-center gap-2 mb-4" do %>
        <div class="w-10 h-10 bg-gradient-to-br from-violet-500 to-indigo-600 rounded-xl flex items-center justify-center shadow-lg shadow-violet-500/30">
          <span class="text-white font-bold">BV</span>
        </div>
        <span class="font-bold text-2xl text-white">BlogVlog</span>
      <% end %>
      <h1 class="text-2xl font-bold text-white mt-2">Create your account</h1>
      <p class="text-gray-400 text-sm mt-1">Join our community of writers and readers</p>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 shadow-2xl shadow-black/50">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-4">
          <div>
            <%= f.label :username, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
            <%= f.text_field :username, autocomplete: "username",
                placeholder: "your_username",
                class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors" %>
            <p class="text-xs text-gray-500 mt-1">Letters, numbers, and underscores only</p>
          </div>

          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-300 mb-1.5" do %>
              Password
              <% if @minimum_password_length %>
                <span class="text-gray-500 font-normal text-xs">(<%= @minimum_password_length %> chars min)</span>
              <% end %>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password",
                class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-300 mb-1.5" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors" %>
          </div>

          <%= f.submit "Create Account", class: "w-full py-3 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40 cursor-pointer mt-2" %>
        </div>
      <% end %>
    </div>

    <p class="text-center text-gray-400 text-sm mt-6">
      Already have an account?
      <%= link_to "Sign in →", new_session_path(resource_name), class: "text-violet-400 hover:text-violet-300 font-medium transition-colors" %>
    </p>
  </div>
</div>
