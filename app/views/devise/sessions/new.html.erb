<div class="min-h-screen flex items-center justify-center px-4 py-16">
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(120,119,198,0.12),rgba(255,255,255,0))] pointer-events-none"></div>

  <div class="relative w-full max-w-md">
    <!-- Logo -->
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-flex items-center gap-2 mb-4" do %>
        <div class="w-10 h-10 bg-gradient-to-br from-violet-500 to-indigo-600 rounded-xl flex items-center justify-center shadow-lg shadow-violet-500/30">
          <span class="text-white font-bold">BV</span>
        </div>
        <span class="font-bold text-2xl text-white">BlogVlog</span>
      <% end %>
      <h1 class="text-2xl font-bold text-white mt-2">Welcome back</h1>
      <p class="text-gray-400 text-sm mt-1">Sign in to your account</p>
    </div>

    <!-- Card -->
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 shadow-2xl shadow-black/50">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-4">
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
                class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-300 mb-1.5" %>
            <%= f.password_field :password, autocomplete: "current-password",
                class: "w-full bg-gray-800 border border-gray-700 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors" %>
          </div>

          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer">
              <%= f.check_box :remember_me, class: "w-4 h-4 accent-violet-500 rounded" %>
              <span class="text-sm text-gray-400">Remember me</span>
            </label>
            <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm text-violet-400 hover:text-violet-300 transition-colors" %>
          </div>

          <%= f.submit "Sign In", class: "w-full py-3 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40 cursor-pointer mt-2" %>
        </div>
      <% end %>
    </div>

    <p class="text-center text-gray-400 text-sm mt-6">
      Don't have an account?
      <%= link_to "Create one →", new_registration_path(resource_name), class: "text-violet-400 hover:text-violet-300 font-medium transition-colors" %>
    </p>
  </div>
</div>
