<nav class="fixed top-0 left-0 right-0 z-40 bg-gray-950/80 backdrop-blur-xl border-b border-gray-800/50" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <div class="flex items-center gap-3">
        <%= link_to root_path, class: "flex items-center gap-2 group" do %>
          <div class="w-8 h-8 bg-gradient-to-br from-violet-500 to-indigo-600 rounded-lg flex items-center justify-center shadow-lg shadow-violet-500/25 group-hover:shadow-violet-500/40 transition-all duration-300 group-hover:scale-110">
            <span class="text-white font-bold text-sm">BV</span>
          </div>
          <span class="font-bold text-xl bg-gradient-to-r from-violet-400 to-indigo-400 bg-clip-text text-transparent">BlogVlog</span>
        <% end %>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-1">
        <%= link_to "Home", root_path, class: nav_link_class(request.path, "/") %>
        <%= link_to "Categories", categories_path, class: nav_link_class(request.path, "/categories") %>
        <%= link_to "Tags", tags_path, class: nav_link_class(request.path, "/tags") %>
        <%= link_to "Archive", archive_path, class: nav_link_class(request.path, "/archive") %>
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-3">

        <!-- Search -->
        <%= link_to search_path, class: "p-2 text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition-colors", title: "Search" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <% end %>

        <% if user_signed_in? %>
          <!-- Admin link -->
          <% if current_user.role_admin? || current_user.role_author? %>
            <%= link_to admin_root_path, class: "hidden md:flex items-center gap-1.5 px-3 py-1.5 text-sm text-violet-400 hover:text-violet-300 hover:bg-violet-500/10 rounded-lg transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
              Dashboard
            <% end %>
          <% end %>

          <!-- User menu -->
          <div class="relative" data-controller="dropdown">
            <button data-action="click->dropdown#toggle" class="flex items-center gap-2 p-1.5 rounded-lg hover:bg-gray-800 transition-colors group">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white font-semibold text-sm">
                <%= current_user.initials %>
              </div>
              <svg class="w-4 h-4 text-gray-400 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>

            <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-48 bg-gray-900 border border-gray-700 rounded-xl shadow-2xl py-1 z-50">
              <div class="px-4 py-2 border-b border-gray-700">
                <p class="text-sm font-medium text-white truncate">@<%= current_user.username %></p>
                <p class="text-xs text-gray-400 truncate"><%= current_user.email %></p>
              </div>
              <%= link_to user_path(current_user.username), class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                Profile
              <% end %>
              <%= link_to edit_user_registration_path, class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-gray-800 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Settings
              <% end %>
              <div class="border-t border-gray-700 mt-1">
                <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center gap-2 px-4 py-2 text-sm text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors text-left" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                  Sign Out
                <% end %>
              </div>
            </div>
          </div>

        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "px-4 py-2 text-sm text-gray-300 hover:text-white transition-colors" %>
          <%= link_to "Get Started", new_user_registration_path, class: "px-4 py-2 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white text-sm font-medium rounded-lg transition-all duration-200 shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40" %>
        <% end %>

        <!-- Mobile menu button -->
        <button class="md:hidden p-2 text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition-colors" data-action="click->navbar#toggleMobile">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div data-navbar-target="mobileMenu" class="hidden md:hidden border-t border-gray-800 py-4 space-y-1">
      <%= link_to "Home", root_path, class: "block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-gray-800 transition-colors" %>
      <%= link_to "Categories", categories_path, class: "block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-gray-800 transition-colors" %>
      <%= link_to "Tags", tags_path, class: "block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-gray-800 transition-colors" %>
      <%= link_to "Archive", archive_path, class: "block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-gray-800 transition-colors" %>
    </div>
  </div>
</nav>

<!-- Spacer -->
<div class="h-16"></div>
