<% content_for :title, "Tags" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-10 text-center">
    <h1 class="text-3xl font-bold text-white mb-2" style="font-family: 'Playfair Display', serif;">All Tags</h1>
    <p class="text-gray-400">Browse posts by tag</p>
  </div>

  <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8">
    <div class="flex flex-wrap gap-3 justify-center">
      <% @tags.each do |tag| %>
        <%= link_to tag_path(tag.slug),
            class: "inline-flex items-center gap-2 px-4 py-2 rounded-full font-medium text-sm hover:opacity-80 transition-all hover:scale-105",
            style: "background-color: #{tag.color}20; color: #{tag.color}; border: 1px solid #{tag.color}30;" do %>
          #<%= tag.name %>
          <span class="text-xs opacity-60 bg-current/10 px-1.5 py-0.5 rounded-full" style="background-color: <%= tag.color %>20"><%= tag.posts_count %></span>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
