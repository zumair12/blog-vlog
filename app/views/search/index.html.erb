<% content_for :title, @query.present? ? "Search: #{@query}" : "Search" %>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Search form -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white mb-6" style="font-family: 'Playfair Display', serif;">Search</h1>
    <%= form_with url: search_path, method: :get do |f| %>
      <div class="flex gap-3">
        <%= f.text_field :q, value: @query, placeholder: "Search articles, topics, authors...", autofocus: true,
            class: "flex-1 bg-gray-900 border border-gray-700 text-white placeholder-gray-500 rounded-xl px-5 py-3.5 text-base focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors" %>
        <%= f.submit "Search",
            class: "px-6 py-3.5 bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white font-medium rounded-xl transition-all cursor-pointer shadow-lg shadow-violet-500/20" %>
      </div>
    <% end %>
  </div>

  <!-- Results -->
  <% if @query.length >= 2 %>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-lg font-semibold text-gray-300">
        <span class="text-white"><%= @posts.total_count rescue @posts.count %></span> results for
        <span class="text-violet-400">"<%= @query %>"</span>
      </h2>
    </div>

    <% if @posts.any? %>
      <div class="space-y-4 mb-8">
        <% @posts.each do |post| %>
          <article class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-gray-700 transition-colors flex gap-4">
            <% if post.featured_image.attached? %>
              <div class="shrink-0 w-20 h-20 rounded-xl overflow-hidden border border-gray-700">
                <%= image_tag post.featured_image, class: "w-full h-full object-cover" %>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <% if post.category %>
                  <span class="text-xs px-2 py-0.5 rounded text-white" style="background-color: <%= post.category.color %>CC;"><%= post.category.name %></span>
                <% end %>
                <span class="text-xs text-gray-500"><%= post.reading_time_text %></span>
              </div>
              <h3 class="font-bold text-white hover:text-violet-300 transition-colors mb-1">
                <%= link_to post.title, post_path(post.slug) %>
              </h3>
              <p class="text-sm text-gray-400 line-clamp-2"><%= post.excerpt %></p>
              <div class="flex items-center gap-2 mt-2 text-xs text-gray-500">
                <span>@<%= post.user.username %></span>
                <span>·</span>
                <span><%= post.published_at&.strftime("%b %d, %Y") %></span>
              </div>
            </div>
          </article>
        <% end %>
      </div>
      <%= render "shared/pagination", collection: @posts %>
    <% else %>
      <div class="text-center py-16">
        <p class="text-5xl mb-4">🔍</p>
        <p class="text-gray-400 text-lg">No results found for "<%= @query %>"</p>
        <p class="text-gray-500 text-sm mt-2">Try different keywords or browse <a href="<%= categories_path %>" class="text-violet-400 hover:underline">categories</a></p>
      </div>
    <% end %>
  <% elsif @query.present? %>
    <p class="text-gray-500 text-sm">Please enter at least 2 characters to search.</p>
  <% end %>
</div>
